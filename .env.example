VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Azure AI Speech — server-side only, never use NEXT_PUBLIC_ or VITE_ prefix
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Server-side only — used to compute deterministic HMAC hashes of
# communication destinations (email/phone/push token) for
# user_communication_blocks.destination_hash. Never use NEXT_PUBLIC_ or
# VITE_ prefix. Generate with e.g. `openssl rand -hex 32`.
COMMUNICATION_SUPPRESSION_HMAC_SECRET=
