# Loaded only by `vite build --mode mobile` (see package.json "cap:sync"),
# never by the plain `vite build` the web deploy runs — the web build stays
# on relative /api/* URLs. Public value, safe to commit: it's just the
# production API origin the packaged Android/iOS app talks to.
#
# To point a mobile build at staging instead, copy this file to
# .env.mobile.staging with the staging URL and build with
# `vite build --mode mobile.staging`.
VITE_API_BASE_URL=https://my.lemonenglish.app
