{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"]
  },
  "include": [
    "api/_ai-gateway/**/*.ts",
    "api/__tests__/ai-gateway.test.ts",
    "api/review-text.ts",
    "api/__tests__/review-text-gateway.test.ts",
    "api/__tests__/cost-calculator.test.ts",
    "api/__tests__/daily-rollup.test.ts",
    "scripts/ai-gateway-reconcile-event.ts",
    "scripts/ai-gateway-reconcile-day.ts",
    "api/generate-theme.ts",
    "api/__tests__/generate-theme-gateway.test.ts",
    "api/compare-rewrite.ts",
    "api/__tests__/compare-rewrite-gateway.test.ts",
    "api/__tests__/_ai-gateway-test-helpers.ts",
    "api/pronunciation-training/[...slug].ts",
    "api/__tests__/pronunciation-generate-text-gateway.test.ts",
    "src/services/listening/story-session/generate-story-session.ts",
    "src/services/listening/story-session/generate-listening-story.ts",
    "src/services/listening/story-session/story-session-gateway.test.ts",
    "src/services/listening/on-demand/process-listening-generation-step.ts",
    "src/services/listening/on-demand/process-listening-generation-step-gateway.test.ts",
    "src/services/listening/prepare-listening-subtitles.ts",
    "src/services/listening/generate-listening-questions.ts",
    "src/services/listening/generate-listening-story.ts",
    "src/services/listening/listening-ai-callfn-gateway.test.ts"
  ]
}
