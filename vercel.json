{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/internal/listening/audit",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/internal/listening/storage-audit",
      "schedule": "0 8 * * 0"
    },
    {
      "path": "/api/internal/listening/cleanup",
      "schedule": "0 9 * * 0"
    }
  ]
}
