{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "microphone=(self), camera=()" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self'" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/internal/listening/audit",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/internal/listening/storage-audit",
      "schedule": "0 8 * * 0"
    },
    {
      "path": "/api/internal/listening/cleanup",
      "schedule": "0 9 * * 0"
    }
  ]
}
